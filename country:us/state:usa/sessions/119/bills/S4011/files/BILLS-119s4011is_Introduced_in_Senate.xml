<distribution-code display="yes">II</distribution-code><congress>119th CONGRESS</congress><session>2d Session</session><legis-num>S. 4011</legis-num><current-chamber>IN THE SENATE OF THE UNITED STATES</current-chamber><action><action-date date="20260305">March 5, 2026</action-date><action-desc><sponsor name-id="S337">Mr. Coons</sponsor> (for himself, <cosponsor name-id="S431">Mr. Curtis</cosponsor>, <cosponsor name-id="S359">Mr. Heinrich</cosponsor>, and <cosponsor name-id="S384">Mr. Tillis</cosponsor>) introduced the following bill; which was read twice and referred to the <committee-name committee-id="SSFR00">Committee on Foreign Relations</committee-name></action-desc></action><legis-type>A BILL</legis-type><official-title>To reauthorize the Tropical Forest and Coral Reef Conservation Act of 1998.</official-title></form><legis-body display-enacting-clause="yes-display-enacting-clause"><section section-type="section-one" id="S1"><enum>1.</enum><header>Short title</header><text display-inline="no-display-inline">This Act may be cited as the <quote><short-title>Tropical Forest and Coral Reef Conservation Reauthorization Act of 2026</short-title></quote>.</text></section><section id="idCEF9976597CA42BEA33636187FA0FD42"><enum>2.</enum><header>Reauthorization</header><text display-inline="no-display-inline">Section 806(d) of the Tropical Forest and Coral Reef Conservation Act of 1998 (<external-xref legal-doc="usc" parsable-cite="usc/22/2431d">22 U.S.C. 2431d(d)</external-xref>) is amended by adding at the end the following new paragraphs:</text><quoted-block style="OLC" id="id5A96F044A9C44474AC2FCD56EEAC5C06" act-name=""><paragraph id="idD35681C8110C4805B1D0C2FC9EF8B1B7"><enum>(14)</enum><text>$20,000,000 for fiscal year 2028.</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="id52f0fc698e82406a95735f8421d9b391"><enum>(15)</enum><text display-inline="yes-display-inline">$20,000,000 for fiscal year 2029.</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="id1a83bae6e6934afd828738a8d9d1607e"><enum>(16)</enum><text display-inline="yes-display-inline">$20,000,000 for fiscal year 2030.</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="id2c57400274604741b8b7c91de81121fa"><enum>(17)</enum><text display-inline="yes-display-inline">$20,000,000 for fiscal year 2031.</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="id4effa8ade51141ef8f8320190cc00b24"><enum>(18)</enum><text display-inline="yes-display-inline">$20,000,000 for fiscal year 2032.</text></paragraph><after-quoted-block>.</after-quoted-block></quoted-block></section></legis-body></bill>

