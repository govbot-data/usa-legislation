                        </clause>
                        <clause commented="no" display-inline="no-display-inline" id="id908314dfd1cf4709a959e5db585db0cd">
                            <enum>(ii)</enum>
 <text display-inline="yes-display-inline">by striking <quote>with respect</quote> and inserting <quote>(A) Except as provided in subparagraph (B), with respect</quote>;</text>
                        </clause>
                        <clause id="idce7c60b4595248e49cb3c333bcf0b4a1" commented="no" display-inline="no-display-inline">
