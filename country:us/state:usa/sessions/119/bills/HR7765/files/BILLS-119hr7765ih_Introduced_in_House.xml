<distribution-code display="yes">I</distribution-code><congress display="yes">119th CONGRESS</congress><session display="yes">2d Session</session><legis-num display="yes">H. R. 7765</legis-num><current-chamber>IN THE HOUSE OF REPRESENTATIVES</current-chamber><action display="yes"><action-date date="20260303">March 3, 2026</action-date><action-desc><sponsor name-id="F000476">Mr. Frost</sponsor> (for himself and <cosponsor name-id="M001230">Mr. Mackenzie</cosponsor>) introduced the following bill; which was referred to the <committee-name committee-id="HJU00">Committee on the Judiciary</committee-name></action-desc></action><legis-type>A BILL</legis-type><official-title display="yes">To amend the Fair Housing Act to repeal the Thurmond amendment.</official-title></form><legis-body id="H4C730DECBBF746C3BB3BD50070871A98" style="OLC"><section section-type="section-one" id="HDDBBE8DA75DB4538AB94BA4796C8A3B3"><enum>1.</enum><header>Short title</header><text display-inline="no-display-inline">This Act may be cited as the <quote><short-title>Fair Future Act</short-title></quote>.</text></section><section id="H769DE16323C34805902369878F012E5C"><enum>2.</enum><header>Amendment</header><text display-inline="no-display-inline">Section 807(b) of the Fair Housing Act (<external-xref legal-doc="usc" parsable-cite="usc/42/3607">42 U.S.C. 3607(b)</external-xref>) is amended—</text><paragraph id="HB691705B48EB4963A3DE53F215C49A03"><enum>(1)</enum><text>by striking paragraph (4); and</text></paragraph><paragraph id="H30F2F628BB8B447BB843EF395AF7D915"><enum>(2)</enum><text>by redesignating paragraph (5) as paragraph (4).</text></paragraph></section></legis-body></bill> 

