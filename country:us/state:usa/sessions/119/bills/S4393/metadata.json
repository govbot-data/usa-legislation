  ],
  "subject": [],
  "abstracts": [],
  "other_titles": [
    {
      "note": "",
      "title": "A bill to require the head of each Federal agency to submit to the Made in America Office and to Congress an annual report on the implementation of the Build America, Buy America Act that identifies each new and existing Federal financial assistance program for infrastructure that has and has not fully implemented Buy America preference requirements under that Act, and for other purposes."
    }
  ],
