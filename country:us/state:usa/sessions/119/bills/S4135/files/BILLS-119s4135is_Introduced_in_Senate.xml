<distribution-code display="yes">II</distribution-code><congress>119th CONGRESS</congress><session>2d Session</session><legis-num>S. 4135</legis-num><current-chamber>IN THE SENATE OF THE UNITED STATES</current-chamber><action><action-date date="20260318">March 18, 2026</action-date><action-desc><sponsor name-id="S322">Mr. Merkley</sponsor> (for himself, <cosponsor name-id="S435">Mr. Sheehy</cosponsor>, <cosponsor name-id="S247">Mr. Wyden</cosponsor>, <cosponsor name-id="S406">Mr. Kelly</cosponsor>, <cosponsor name-id="S359">Mr. Heinrich</cosponsor>, and <cosponsor name-id="S385">Ms. Cortez Masto</cosponsor>) introduced the following bill; which was read twice and referred to the <committee-name committee-id="SSEV00">Committee on Environment and Public Works</committee-name></action-desc></action><legis-type>A BILL</legis-type><official-title>To reauthorize the Federal lands access program.</official-title></form><legis-body><section id="id4c25f71b7f9d490a95ebb2f7e2bdf47a" section-type="section-one"><enum>1.</enum><header>Short title</header><text display-inline="no-display-inline">This Act may be cited as the <quote><short-title>FLAP Reauthorization Act</short-title></quote>.</text></section><section commented="no" display-inline="no-display-inline" section-type="subsequent-section" id="idb0c71d64063548818abee928741fb769"><enum>2.</enum><header>Federal lands access program</header><text display-inline="no-display-inline">There are authorized to be appropriated out of the Highway Trust Fund (other than the Mass Transit Account) for the Federal lands access program under section 204 of title 23, United States Code—</text><paragraph commented="no" display-inline="no-display-inline" id="id8cb1359c832c48dba2a6a4c011899585"><enum>(1)</enum><text>$313,975,000 for fiscal year 2027;</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="id4e492d16c761429e98e33f3cd215ff51"><enum>(2)</enum><text>$318,975,000 for fiscal year 2028;</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="iddad43a2318244e529d92dd9717d8ab33"><enum>(3)</enum><text>$323,975,000 for fiscal year 2029;</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="idf0a5c3e90cc64faebe9ca18222fc600b"><enum>(4)</enum><text>$328,975,000 for fiscal year 2030; and</text></paragraph><paragraph commented="no" display-inline="no-display-inline" id="id0f129a4e320e4b74b2f58252a3bde911"><enum>(5)</enum><text>$333,975,000 for fiscal year 2031.</text></paragraph></section></legis-body></bill>

