<distribution-code display="yes">I</distribution-code><congress display="yes">119th CONGRESS</congress><session display="yes">1st Session</session><legis-num display="yes">H. R. 6413</legis-num><current-chamber>IN THE HOUSE OF REPRESENTATIVES</current-chamber><action display="yes"><action-date date="20251203">December 3, 2025</action-date><action-desc><sponsor name-id="T000490">Mr. Taylor</sponsor> introduced the following bill; which was referred to the <committee-name committee-id="HED00">Committee on Education and Workforce</committee-name></action-desc></action><legis-type>A BILL</legis-type><official-title display="yes">To amend the Workforce Innovation and Opportunity Act to remove a requirement that 75 percent of certain funds be used to provide youth workforce investment activities for out-of-school youth.</official-title></form><legis-body id="HA92FF171450C4D6DBB58C6DFBDD45302" style="OLC"><section id="H99728D459B6C4D98AC9D66B803385EB5" section-type="section-one"><enum>1.</enum><header>Short title</header><text display-inline="no-display-inline">This Act may be cited as the <quote><short-title>Workforce Flexibility Act</short-title></quote>.</text></section><section id="H8463329E6BDD4663ADB81B745A8F279A"><enum>2.</enum><header>Removal of out-of-school priority</header><text display-inline="no-display-inline">Section 129(a) of the Workforce Innovation and Opportunity Act (<external-xref legal-doc="usc" parsable-cite="usc/29/3164">29 U.S.C. 3164</external-xref>) is amended—</text><paragraph id="H5A06B7F3B6D8479ABB361AAE83705CB4"><enum>(1)</enum><text>by striking paragraph (4); and</text></paragraph><paragraph id="HB35808F0A1F24C3A89A0BC7107C11B98"><enum>(2)</enum><text>by redesignating paragraph (5) as paragraph (4). </text></paragraph></section></legis-body></bill> 

